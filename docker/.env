# System
UID=1000
GID=1000

# Php
PHP_NAME=container-settings
PHP_DOCKERFILE=docker/php/Dockerfile
PHP_CONTEXT=../
PHP_VERSION=fpm-alpine
PHP_PORT=9000
PHP_CONFIG_SOURCE=docker/php/php.ini
PHP_CONFIG_TARGET=/usr/local/etc/php/php.ini
PHP_ENTRYPOINT_SOURCE=docker/php/entrypoint.sh
PHP_ENTRYPOINT_TARGET=/entrypoint.sh
PHP_CODE_SOURCE=./../code
PHP_CODE_TARGET=/code
